PORT=3000
NODE_ENV=production

# MySQL
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=campus_runner
MYSQL_USER=campus_runner
MYSQL_PASSWORD=change_me

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Rate limit
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120

# WeChat
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret
WECHAT_MCH_ID=your_wechat_mch_id
WECHAT_MCH_KEY=your_wechat_mch_key

# Tencent Cloud
TENCENT_MAP_KEY=your_tencent_map_key
TENCENT_IM_SDKAPPID=your_tencent_im_sdkappid
TENCENT_IM_SECRET_KEY=your_tencent_im_secret_key
TENCENT_COS_BUCKET=your_cos_bucket
TENCENT_COS_REGION=ap-guangzhou
TENCENT_COS_SECRET_ID=your_cos_secret_id
TENCENT_COS_SECRET_KEY=your_cos_secret_key

# Content safety
CONTENT_SAFETY_PROVIDER=tencent
